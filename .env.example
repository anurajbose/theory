# ============================================================
# THEORY — environment / secrets contract (authoritative)
# Copy to .env (dev) or inject via your secrets manager (staging/prod).
# NEVER commit a real .env. Generate secrets:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# ============================================================

# ── Core ──────────────────────────────────────────────────────────────────────
NODE_ENV=development                 # production in staging/prod
PORT=4000
APP_URL=http://localhost:3000        # used in password-reset links
FRONTEND_URL=http://localhost:3000   # CORS + Socket.IO origin (comma-sep allowed)
APP_VERSION=1.0.0
LOG_LEVEL=info                       # debug|info|warn|error

# ── Database (REQUIRED) ───────────────────────────────────────────────────────
DATABASE_URL=postgresql://pulse:password@localhost:5432/pulse_db

# ── Auth / crypto (REQUIRED — distinct random values) ─────────────────────────
JWT_SECRET=replace_with_random_64char
JWT_REFRESH_SECRET=replace_with_different_random_64char
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
# Journal/MFA-secret AES-256-GCM key. Rotate independently; falls back to
# JWT_SECRET if unset (NOT recommended for prod).
JOURNAL_SECRET=replace_with_another_random_64char
MFA_ISSUER=THEORY

# ── Redis / queues (optional — app degrades gracefully if down) ───────────────
REDIS_URL=redis://localhost:6379
QUEUES_ENABLED=true
QUEUE_CONCURRENCY=5
ENABLE_QUEUE_DASHBOARD=false
QUEUE_DASHBOARD_TOKEN=                # required if dashboard enabled

# ── OpenSearch (optional — search disabled if unset) ──────────────────────────
OPENSEARCH_URL=
OPENSEARCH_USER=
OPENSEARCH_PASS=
OPENSEARCH_INDEX_PREFIX=theory
OPENSEARCH_TLS_INSECURE=false

# ── Observability (optional — tracing off unless set) ─────────────────────────
OTEL_ENABLED=false
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=theory-api

# ── AI (optional — governed fallback unless fully set) ────────────────────────
AI_ENABLED=false
AI_PROVIDER_URL=                      # e.g. https://api.openai.com/v1/chat/completions
AI_API_KEY=

# ── Email (optional — logs to console if SMTP unset) ──────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=THEORY <no-reply@theory.local>

# ── Billing ───────────────────────────────────────────────────────────────────
RAZORPAY_WEBHOOK_SECRET=              # required to accept Razorpay webhooks
# STRIPE_* — tracked follow-up (webhook returns 501 until wired)

# ── Exports / storage ─────────────────────────────────────────────────────────
EXPORT_DIR=                           # default: <tmp>/theory-exports
EXPORT_SIGN_SECRET=                   # falls back to JWT_SECRET

# ── SSO (Google OIDC reference path) ──────────────────────────────────────────
GOOGLE_CLIENT_ID=
VITE_GOOGLE_CLIENT_ID=                # frontend build-time
